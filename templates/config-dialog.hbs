{{!-- Cyberware config dialog template
  Expected data: item, data (cyberData), slotOptions, categoryOptions, qualityOptions
--}}
<form class="cyberware-config-form">

  <div class="form-group">
    <label>{{localize "CYBERWARE.Category"}}</label>
    <select name="category">
      {{#each categoryOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "CYBERWARE.Slot"}}</label>
    <select name="slot">
      {{#each slotOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label>{{localize "CYBERWARE.HumanityCostDice"}}</label>
    <div class="form-fields">
      <input type="text" name="humanityCostDice"
             value="{{data.humanityCostDice}}" placeholder="2d6">
    </div>
    <p class="hint">{{localize "CYBERWARE.HumanityCostDiceHint"}}</p>
  </div>

  <div class="form-group">
    <label>{{localize "CYBERWARE.CraftQuality"}}</label>
    <select name="craftQuality">
      {{#each qualityOptions}}
        <option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>
      {{/each}}
    </select>
  </div>

  <div class="form-group">
    <label class="checkbox">
      <input type="checkbox" name="malfunctionEnabled"
             {{#if data.malfunction.enabled}}checked{{/if}}>
      {{localize "CYBERWARE.CanMalfunction"}}
    </label>
    <div class="form-fields">
      <input type="number" name="malfunctionThreshold"
             value="{{data.malfunction.threshold}}" min="3" max="18">
    </div>
    <p class="hint">{{localize "CYBERWARE.MalfunctionHint"}}</p>
  </div>

  <div class="form-group">
    <label class="checkbox">
      <input type="checkbox" name="maintenanceRequired"
             {{#if data.maintenance.required}}checked{{/if}}>
      {{localize "CYBERWARE.RequiresMaintenance"}}
    </label>
    <div class="form-fields">
      <input type="number" name="maintenanceCost"
             value="{{data.maintenance.cost}}" min="0">
    </div>
    <p class="hint">{{localize "CYBERWARE.MaintenanceCostHint"}}</p>
  </div>

</form>
